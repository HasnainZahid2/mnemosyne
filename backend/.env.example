# Qwen Cloud (OpenAI-compatible). Copy this file to .env and fill in your key.
DASHSCOPE_API_KEY=sk-your-key-here
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_CHAT_MODEL=qwen-plus
QWEN_EMBED_MODEL=text-embedding-v3

# Alibaba Cloud OSS (for memory persistence proof). Fill these in for the OSS path.
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_ENDPOINT=https://oss-ap-southeast-1.aliyuncs.com
OSS_BUCKET=mnemosyne-memories
